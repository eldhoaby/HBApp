# -----------------------------------------------------------------------------
# HOMYSTAY - Environment Variables Template
# -----------------------------------------------------------------------------
# Instructions:
# 1. Create a '.env' file in `backend/` using the [BACKEND] section below.
# 2. Create a '.env' file in `frontend/` using the [FRONTEND] section below.
# 3. DO NOT commit actual `.env` files to version control.
# -----------------------------------------------------------------------------

# [BACKEND]  →  backend/.env
# Server Configuration
PORT=3000

# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net

# Admin Credentials
ADMIN_EMAIL=your_admin_email@gmail.com
ADMIN_PASSWORD=your_admin_password

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# CORS (production only)
FRONTEND_URL=http://localhost:5173

# [FRONTEND]  →  frontend/.env
# API Base URL (production: your Render backend URL)
VITE_API_BASE_URL=http://localhost:3000

# Frontend Payment Keys
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
